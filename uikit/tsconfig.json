{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowJs": false,
    "skipLibCheck": true,
    "paths": {
       "*": ["./@mf-types/*"]
    }
  },
  // "include": [
  //   "src/**/*",
  //   "**/*.d.ts",
  // ],
  "include": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx"],
